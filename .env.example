# ==========================================================================
# Finix — exemplo de variáveis de ambiente.
# Copie para `.env` e ajuste os valores. NUNCA versione o `.env` real.
#   cp .env.example .env
# ==========================================================================

# --- Banco de dados (Postgres) ---
POSTGRES_USER=finix
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finix

# URL usada pelo backend. Dentro do Docker Compose o host é "db" (nome do serviço).
# Para rodar o backend fora do Docker, troque "db" por "localhost".
DATABASE_URL=postgresql+psycopg://finix:changeme@db:5432/finix

# --- Backend ---
ENVIRONMENT=development
# Gere algo aleatório, ex.: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=troque-este-valor-em-producao
# Origens permitidas no CORS, separadas por vírgula.
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- LLM (camada opcional — desligada por padrão, ver PROJECT.md §10) ---
LLM_ENABLED=false
LLM_PROVIDER=
LLM_API_KEY=

# --- Frontend ---
VITE_API_URL=http://localhost:8000
